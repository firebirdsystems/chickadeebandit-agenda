{
  "id": "agenda",
  "name": "Agenda",
  "version": "1.0.0",
  "description": "Run structured meetings for your household or organization. Collect agenda items, track action items, and capture notes.",
  "entrypoint": "index.html",
  "runtime": "static",
  "storage": "db",
  "category": "general",
  "tags": ["meetings", "agenda", "action-items", "notes"],
  "data_access": {
    "reads": ["family.members", "family.groups"],
    "writes": []
  },
  "exports": ["calendar_events"],
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "row_policies": {
    "meetings": {
      "kind": "owner_or_visibility",
      "member_column": "created_by",
      "visibility_column": "audience",
      "everyone_values": ["everyone"],
      "adult_values": ["adults"],
      "write_owner_only": false
    },
    "agenda_items": {
      "kind": "owner_or_visibility",
      "member_column": "submitted_by",
      "visibility_column": "audience",
      "everyone_values": ["everyone"],
      "adult_values": ["adults"],
      "write_owner_only": false
    },
    "action_items": {
      "kind": "owner_or_visibility",
      "member_column": "created_by",
      "visibility_column": "audience",
      "everyone_values": ["everyone"],
      "adult_values": ["adults"],
      "write_owner_only": false
    }
  },
  "resource_limits": {
    "max_db_bytes": 10485760
  },
  "nav": {
    "label": "Agenda"
  },
  "widget": {
    "label": "Agenda",
    "size": "medium"
  },
  "icon": "📋",
  "ai_access": {
    "allowed": true,
    "mode": "read",
    "db_exports": ["upcoming_meetings", "open_action_items"]
  }
}
